generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String
  content   String
  date      DateTime @default(now())
  readTime  String
  tags      String[]
  category  String
  featured  Boolean  @default(false)
  published Boolean  @default(false)
  bannerImage String?
  views     Int      @default(0)
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("posts")
}

model Visitor {
  id           String   @id @default(cuid())
  fingerprint  String   @unique
  firstSeenAt  DateTime @default(now())
  lastSeenAt   DateTime @updatedAt
  userAgent    String?
  browser      String?
  os           String?
  device       String?
  screenWidth  Int?
  screenHeight Int?
  language     String?
  timezone     String?

  // Geolocation (server-side, from Vercel headers)
  country    String?
  region     String?
  city       String?
  ip         String?

  // Enhanced hardware signals (client-side)
  colorDepth     Int?
  pixelRatio     Float?
  deviceMemory   Float?
  maxTouchPoints Int?
  platform       String?
  cpuCores       Int?
  connectionType String?

  // Advanced fingerprint signals (client-side, raw)
  canvasData    String?
  webglVendor   String?
  webglRenderer String?
  audioData     String?

  sessions Session[]

  @@index([lastSeenAt])
  @@index([firstSeenAt])
  @@index([country])
  @@index([city])
  @@map("visitors")
}

model Session {
  id          String   @id
  visitorId   String
  visitor     Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  duration    Int?
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  entryPage   String
  pageCount   Int      @default(0)
  eventCount  Int      @default(0)

  pageViews PageView[]
  events    TrackingEvent[]

  @@index([visitorId])
  @@index([startedAt])
  @@map("sessions")
}

model PageView {
  id          String   @id @default(cuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  path        String
  title       String?
  timestamp   DateTime @default(now())
  duration    Int?
  scrollDepth Int?

  @@index([sessionId])
  @@index([path])
  @@index([timestamp])
  @@map("page_views")
}

model TrackingEvent {
  id         String   @id @default(cuid())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name       String
  category   String
  path       String
  properties Json?
  timestamp  DateTime @default(now())

  @@index([sessionId])
  @@index([name])
  @@index([timestamp])
  @@index([category])
  @@map("tracking_events")
}
